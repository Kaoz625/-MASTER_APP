{
  "name": "master-app-backend",
  "version": "1.0.0",
  "description": "Universal app backend - Node.js/Express/Firebase/Supabase/Stripe",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "test:integration": "jest --testPathPattern=integration",
    "test:e2e": "playwright test",
    "migrate": "node database/scripts/migrate.js",
    "seed": "node database/scripts/seed.js",
    "lint": "eslint src/**/*.js",
    "lint:fix": "eslint src/**/*.js --fix",
    "format": "prettier --write \"src/**/*.js\"",
    "check-updates": "node ../scripts/check-updates.js",
    "update-dependencies": "npm update && npm audit fix",
    "build": "npm install && npm run migrate && npm run seed",
    "docker:build": "docker build -t master-app-backend .",
    "docker:run": "docker run -p 3000:3000 --env-file .env master-app-backend",
    "pm2:start": "pm2 start ecosystem.config.js",
    "pm2:stop": "pm2 stop ecosystem.config.js",
    "pm2:restart": "pm2 restart ecosystem.config.js",
    "pm2:logs": "pm2 logs"
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "dotenv": "^16.3.1",
    "firebase-admin": "^12.0.0",
    "@supabase/supabase-js": "^2.39.3",
    "stripe": "^14.10.0",
    "pg": "^8.11.3",
    "bcrypt": "^5.1.1",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^6.9.7",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "multer": "^1.4.5-lts.1",
    "morgan": "^1.10.0",
    "compression": "^1.7.4",
    "twilio": "^4.19.3",
    "uuid": "^9.0.1",
    "axios": "^1.6.5",
    "web-speech-api": "latest",
    "socket.io": "^4.5.4"
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "jest": "^29.7.0",
    "supertest": "^6.3.3",
    "eslint": "^8.55.0",
    "prettier": "^3.1.1",
    "@playwright/test": "^1.40.1",
    "pm2": "^5.3.0"
  },
  "engines": {
    "node": ">=25.0.0",
    "npm": ">=11.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Kaoz625/MASTER_APP.git"
  },
  "keywords": [
    "master-app",
    "universal-app",
    "multi-platform",
    "authentication",
    "payments",
    "parent-controls",
    "age-based",
    "voice-navigation",
    "maps",
    "firebase",
    "supabase",
    "stripe",
    "stripe-connect"
  ],
  "author": "Markus Schecher <NYCTailblazers@gmail.com>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/Kaoz625/MASTER_APP/issues"
  },
  "homepage": "https://github.com/Kaoz625/MASTER_APP#readme"
}
